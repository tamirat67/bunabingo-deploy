# Route all /validate/ID requests to index.php via PATH_INFO
Options -MultiViews
RewriteEngine On

# Allow direct file access
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route /validate/ID → index.php with PATH_INFO
RewriteRule ^validate/([A-Za-z0-9_-]+)$ index.php/validate/$1 [QSA,L]

# Route everything else to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
