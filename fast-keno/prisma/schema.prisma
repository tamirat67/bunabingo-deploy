
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoomType {
  DEMO
  CASUAL
  STANDARD
  PRO
  JACKPOT
  VIP
  SPIN_10
  SPIN_20
  SPIN_50
  SPIN_100
}

enum GameStatus {
  WAITING
  COUNTDOWN
  RUNNING
  FINISHED
  CANCELLED
}

enum WinMode {
  ROW
  COLUMN
  DIAGONAL
  FOUR_CORNERS
  FULL_HOUSE
}

model User {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  telegramId       BigInt   @unique @map("telegram_id")
  username         String?
  telegramUsername String?  @map("telegram_username")
  firstName        String?  @map("first_name")
  lastName         String?  @map("last_name")
  phone            String?
  phoneNumber      String?  @map("phone_number") // Some parts of code use this
  passwordHash     String?  @map("password_hash")
  referralCode     String?  @unique @map("referral_code")
  referredBy       String?  @db.Uuid @map("referred_by")
  role             String   @default("PLAYER")
  isAdmin          Boolean  @default(false) @map("is_admin")
  status           String   @default("ACTIVE")
  hasSeenJackpot   Boolean  @default(false) @map("has_seen_jackpot")
  depositPhones    Json?    @map("deposit_phones")
  isBot            Boolean  @default(false) @map("is_bot")
  lastActiveAt     DateTime @default(now()) @db.Timestamptz(6) @map("last_active_at")
  createdAt        DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  wallet               Wallet?
  agentPreDepositWallet AgentPreDepositWallet?
  deposits             Deposit[]
  withdrawals          Withdrawal[]
  transactions         Transaction[]
  adminLogs            AdminLog[]    @relation("AdminActor")
  auditLogs            AdminLog[]    @relation("AuditUser")
  tickets              Ticket[]
  winners              Winner[]
  agentCommissionLogs  AgentCommissionLog[]
  agentSettlements     AgentSettlement[] @relation("AgentSettlements")
  adminSettlements     AgentSettlement[] @relation("AdminSettlements")
  aviatorBets          AviatorBet[]

  // Self-relation for referrals
  referrer         User?    @relation("UserReferrals", fields: [referredBy], references: [id])
  referrals        User[]   @relation("UserReferrals")

  kenoTickets          KenoTicket[]
  kenoAuditLogs        KenoAuditLog[]
  kenoRgLimits         KenoRgLimit[]

  @@map("users")
}

model Wallet {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @unique @db.Uuid @map("user_id")
  balance          Decimal  @default(0) @db.Decimal(20, 4)
  credit           Decimal  @default(0) @db.Decimal(20, 4)
  commissionRate   Decimal  @default(0.25) @db.Decimal(5, 4) @map("commission_rate")
  referralBalance  Decimal  @default(0) @db.Decimal(20, 4) @map("referral_balance")
  bonusBalance     Decimal  @default(0) @db.Decimal(20, 4) @map("bonus_balance")
  aviatorBalance   Decimal  @default(0) @db.Decimal(20, 4) @map("aviator_balance")
  coins            Int      @default(0)
  totalDeposited   Decimal  @default(0) @db.Decimal(20, 4) @map("total_deposited")
  totalWithdrawn   Decimal  @default(0) @db.Decimal(20, 4) @map("total_withdrawn")
  totalWon         Decimal  @default(0) @db.Decimal(20, 4) @map("total_won")
  totalSpent       Decimal  @default(0) @db.Decimal(20, 4) @map("total_spent")
  createdAt        DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt        DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Room {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type           RoomType @unique
  ticketPrice    Decimal  @db.Decimal(20, 4) @map("ticket_price")
  minPlayers     Int      @default(2) @map("min_players")
  maxPlayers     Int      @default(100) @map("max_players")
  currentPlayers Int      @default(0) @map("current_players")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  games          Game[]

  @@map("rooms")
}

model Game {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId           String      @db.Uuid @map("room_id")
  status           GameStatus  @default(WAITING)
  totalPrize       Decimal     @default(0) @db.Decimal(20, 4) @map("total_prize")
  houseEdge        Decimal     @default(0) @db.Decimal(20, 4) @map("house_edge")
  countdownSeconds Int?        @map("countdown_seconds")
  startedAt        DateTime?   @db.Timestamptz(6) @map("started_at")
  finishedAt       DateTime?   @db.Timestamptz(6) @map("finished_at")
  cancelledAt      DateTime?   @db.Timestamptz(6) @map("cancelled_at")
  cancelReason     String?     @map("cancel_reason")
  createdAt        DateTime    @default(now()) @db.Timestamptz(6) @map("created_at")

  room             Room        @relation(fields: [roomId], references: [id])
  tickets          Ticket[]
  winners          Winner[]
  drawHistory      DrawHistory[]

  @@index([roomId])
  @@map("games")
}

model Ticket {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @db.Uuid @map("user_id")
  gameId        String   @db.Uuid @map("game_id")
  card          Json
  markedNumbers Json     @map("marked_numbers")
  isWinner      Boolean  @default(false) @map("is_winner")
  purchasedAt   DateTime @default(now()) @db.Timestamptz(6) @map("purchased_at")

  user          User     @relation(fields: [userId], references: [id])
  game          Game     @relation(fields: [gameId], references: [id])
  winners       Winner[]

  @@index([userId])
  @@index([gameId])
  @@index([userId, gameId])
  @@map("tickets")
}

model Winner {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gameId      String   @db.Uuid @map("game_id")
  userId      String   @db.Uuid @map("user_id")
  ticketId    String   @db.Uuid @map("ticket_id")
  winMode     WinMode  @map("win_mode")
  prizeAmount Decimal  @db.Decimal(20, 4) @map("prize_amount")
  paidAt      DateTime @default(now()) @db.Timestamptz(6) @map("paid_at")

  game        Game     @relation(fields: [gameId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  ticket      Ticket   @relation(fields: [ticketId], references: [id])

  @@index([gameId])
  @@index([userId])
  @@index([ticketId])
  @@map("winners")
}

model DrawHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gameId    String   @db.Uuid @map("game_id")
  number    Int
  sequence  Int
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  game      Game     @relation(fields: [gameId], references: [id])

  @@index([gameId])
  @@map("draw_history")
}

model Deposit {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @db.Uuid @map("user_id")
  amount      Decimal  @db.Decimal(20, 4)
  txnId       String   @unique @map("txn_id")
  receiptUrl  String?  @map("receipt_url")
  details     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("deposits")
}

model Withdrawal {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?  @db.Uuid @map("user_id")
  amount        Decimal  @db.Decimal(20, 4)
  bankName      String   @map("bank_name")
  accountNumber String   @map("account_number")
  accountName   String   @map("account_name")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("withdrawals")
}

model Transaction {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @db.Uuid @map("user_id")
  type          String
  amount        Decimal  @db.Decimal(20, 4)
  balanceBefore Decimal  @db.Decimal(20, 4) @map("balance_before")
  balanceAfter  Decimal  @db.Decimal(20, 4) @map("balance_after")
  status        String   @default("completed")
  referenceId   String?  @map("reference_id")
  description   String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([referenceId])
  @@map("transactions")
}

model AdminLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId      String   @db.Uuid @map("admin_id")
  action       String
  targetUserId String?  @db.Uuid @map("target_user_id")
  details      Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  admin        User     @relation("AdminActor", fields: [adminId], references: [id])
  targetUser   User?    @relation("AuditUser", fields: [targetUserId], references: [id])

  @@map("admin_logs")
}

// ── Agent Pre-Deposit Commission Wallet ───────────────────────────────────
// One row per Agent. Funded manually (recharge). Auto-debited 6.25% per game.
// Games are hard-blocked when balance < required commission for that game.
model AgentPreDepositWallet {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId         String   @unique @db.Uuid @map("agent_id")
  balance         Decimal  @default(0) @db.Decimal(20, 4)
  totalDebited    Decimal  @default(0) @db.Decimal(20, 4) @map("total_debited")
  totalRecharged  Decimal  @default(0) @db.Decimal(20, 4) @map("total_recharged")
  createdAt       DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt       DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  agent           User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  commissionLogs  AgentCommissionLog[]

  @@map("agent_pre_deposit_wallets")
}

// Every 6.25% deduction and every recharge is logged here for full audit trail
model AgentCommissionLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId     String   @db.Uuid @map("agent_id")
  walletId    String   @db.Uuid @map("wallet_id")
  type        String   // 'COMMISSION_DEBIT' | 'RECHARGE'
  amount      Decimal  @db.Decimal(20, 4)
  gameId      String?  @map("game_id")     // nullable — recharges have no game
  totalSales  Decimal? @db.Decimal(20, 4) @map("total_sales")
  description String?
  balanceBefore Decimal @db.Decimal(20, 4) @map("balance_before")
  balanceAfter  Decimal @db.Decimal(20, 4) @map("balance_after")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  agent       User                  @relation(fields: [agentId], references: [id])
  wallet      AgentPreDepositWallet @relation(fields: [walletId], references: [id])

  @@map("agent_commission_logs")
}

model Jackpot {
  id                  String   @id @default("GLOBAL")
  currentAmount       Decimal  @default(0) @db.Decimal(18, 2) @map("current_amount")
  targetAmount        Decimal  @default(1000) @db.Decimal(18, 2) @map("target_amount")
  minTickets          Int      @default(20) @map("min_tickets")
  contributionPercent Decimal  @default(0.01) @db.Decimal(5, 4) @map("contribution_percent")
  lastWonAt           DateTime @default(now()) @db.Timestamptz(6) @map("last_won_at")
  lastWinnerId        String?  @map("last_winner_id")
  updatedAt           DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  @@map("jackpots")
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  @@map("system_settings")
}

model Promotion {
  id          String   @id @default(cuid())
  title       String
  message     String
  type        String   @default("daily")   // "daily" | "weekly" | "announcement" | "custom"
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  scheduledAt DateTime? @map("scheduled_at") @db.Timestamptz(6)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(6)
  sentAt      DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  @@map("promotions")
}

model SystemWallet {
  id        Int      @id @default(1)
  balance   Decimal  @default(0.0) @db.Decimal(20, 2)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_wallets")
}

model GameCycle {
  roomType   String   @id @map("room_type")
  totalGames Int      @default(0) @map("total_games")
  houseWins  Int      @default(0) @map("house_wins")
  playerWins Int      @default(0) @map("player_wins")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("game_cycles")
}

model HouseSettings {
  id              Int      @id @default(1)
  forceHouseWin   Boolean  @default(true)
  rouletteFix     Boolean  @default(true)
  bingoWinRate    Int      @default(100)
  updatedAt       DateTime @updatedAt

  @@map("house_settings")
}

// ─── Agent Cash Settlement Checkpoints ────────────────────────
// When admin collects physical cash from an agent, a checkpoint is created.
// Future "Current Period" reports only calculate totals after this exact timestamp.
model AgentSettlement {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId     String   @db.Uuid @map("agent_id")
  adminId     String   @db.Uuid @map("admin_id") // Who collected it
  amount      Decimal  @db.Decimal(20, 4)
  periodStart DateTime @db.Timestamptz(6) @map("period_start")
  periodEnd   DateTime @default(now()) @db.Timestamptz(6) @map("period_end")
  notes       String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  agent       User     @relation("AgentSettlements", fields: [agentId], references: [id])
  admin       User     @relation("AdminSettlements", fields: [adminId], references: [id])

  @@index([agentId])
  @@map("agent_settlements")
}

model AviatorGame {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status           GameStatus  @default(WAITING)
  crashMultiplier  Decimal?    @db.Decimal(10, 4) @map("crash_multiplier")
  startedAt        DateTime?   @db.Timestamptz(6) @map("started_at")
  finishedAt       DateTime?   @db.Timestamptz(6) @map("finished_at")
  createdAt        DateTime    @default(now()) @db.Timestamptz(6) @map("created_at")

  bets             AviatorBet[]

  @@map("aviator_games")
}

model AviatorBet {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gameId            String      @db.Uuid @map("game_id")
  userId            String      @db.Uuid @map("user_id")
  betAmount         Decimal     @db.Decimal(20, 4) @map("bet_amount")
  targetMultiplier  Decimal?    @db.Decimal(10, 4) @map("target_multiplier") // auto-cashout target
  cashoutMultiplier Decimal?    @db.Decimal(10, 4) @map("cashout_multiplier") // actual cashout
  winAmount         Decimal?    @db.Decimal(20, 4) @map("win_amount")
  status            String      @default("PENDING") // PENDING, WON, LOST
  createdAt         DateTime    @default(now()) @db.Timestamptz(6) @map("created_at")

  game              AviatorGame @relation(fields: [gameId], references: [id])
  user              User        @relation(fields: [userId], references: [id])

  @@index([gameId])
  @@index([userId])
  @@map("aviator_bets")
}

// ============================================================
// Fast Keno models
// ============================================================

model KenoRound {
  id              BigInt   @id @default(autoincrement())
  roundCode       String   @unique @map("round_code")
  tableId         String   @default("default") @map("table_id")
  status          String   @default("BETTING_OPEN") // BETTING_OPEN | BETTING_CLOSED | DRAWING | REVEALING | SETTLED
  serverSeedHash  String   @map("server_seed_hash")
  serverSeed      String?  @map("server_seed")
  clientSeed      String?  @map("client_seed")
  nonce           BigInt   @default(0)
  drawnNumbers    Int[]    @map("drawn_numbers")
  bettingClosesAt DateTime @map("betting_closes_at")
  drawnAt         DateTime? @map("drawn_at")
  settledAt       DateTime? @map("settled_at")
  createdAt       DateTime @default(now()) @map("created_at")

  // Pari-Mutuel Pool Tracking
  totalStakeCents BigInt?  @map("total_stake_cents")
  houseRakeCents  BigInt?  @map("house_rake_cents")
  prizePoolCents  BigInt?  @map("prize_pool_cents")
  totalShares     Decimal? @map("total_shares") @db.Decimal(20,4)

  tickets KenoTicket[]

  @@index([status])
  @@index([createdAt])
  @@map("keno_rounds")
}

model KenoTicket {
  id              BigInt   @id @default(autoincrement())
  roundId         BigInt   @map("round_id")
  round           KenoRound @relation(fields: [roundId], references: [id])
  userId          String   @db.Uuid @map("user_id")
  user            User     @relation(fields: [userId], references: [id])

  numbers         Int[]    @map("picks")
  stakeCents      Int      @map("stake_cents")
  hits            Int?     @map("matches")
  payoutCents     Int?     @default(0) @map("payout_cents")
  status          String   @default("PLACED") // PLACED | WON | LOST | VOID | DEBIT_FAILED | CREDIT_FAILED
  idempotencyKey  String   @unique @map("idempotency_key")
  walletDebitRef  String?  @map("wallet_debit_ref")
  walletCreditRef String?  @map("wallet_credit_ref")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([roundId])
  @@index([userId, createdAt])
  @@map("keno_tickets")
}

model KenoPayoutRule {
  id                BigInt  @id @default(autoincrement())
  spotCount         Int     @map("picks_count")
  hits              Int     @map("matches_count")
  multiplier        Decimal @map("payout_multiplier") @db.Decimal(10, 2)
  effectiveFrom     DateTime @default(now()) @map("effective_from")

  @@unique([spotCount, hits])
  @@map("keno_payout_table")
}

model KenoConfig {
  configKey   String   @id @map("config_key")
  configValue String   @map("config_value")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("keno_config")
}

model KenoAuditLog {
  id          BigInt   @id @default(autoincrement())
  ticketId    BigInt?  @map("ticket_id")
  roundId     BigInt?  @map("round_id")
  userId      String?  @db.Uuid @map("user_id")
  action      String   // BET_PLACED | DEBIT_FAILED | PAYOUT_CREDITED | VOID_REFUNDED
  severity    String   @default("INFO") // INFO | CRITICAL
  amountCents Int?     @map("amount_cents")
  detail      Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("keno_audit_log")
}

model KenoRgLimit {
  id          BigInt   @id @default(autoincrement())
  userId      String   @db.Uuid @map("user_id")
  period      String   // DAILY | WEEKLY | MONTHLY | FOREVER
  type        String   // DEPOSIT | LOSS | WAGER | SELF_EXCLUDED
  amountCents Int?     @map("amount_cents")
  until       DateTime? 
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("keno_rg_limits")
}
