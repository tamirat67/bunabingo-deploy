// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  PLAYER
  AGENT
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
}

enum RoomType {
  DEMO       // Free practice
  CASUAL     // 2+ players, ticket: $10
  STANDARD   // 5+ players, ticket: $20
  PRO        // 10+ players, ticket: $50
  JACKPOT    // 20+ players, ticket: $100
  VIP        // VIP room, ticket: $200
  SPIN_10    // Instant win: $10
  SPIN_20    // Instant win: $20
  SPIN_50    // Instant win: $50
  SPIN_100   // Instant win: $100
}

enum GameStatus {
  WAITING     // Accepting players
  COUNTDOWN   // Countdown started
  RUNNING     // Numbers being drawn
  FINISHED    // Game over
  CANCELLED   // Not enough players
}

enum WinMode {
  ROW
  COLUMN
  DIAGONAL
  FOUR_CORNERS
  FULL_HOUSE
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TICKET_PURCHASE
  PRIZE_WIN
  REFUND
  REFERRAL_BONUS
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

// ─────────────────────────────────────────────
//  MODELS
// ─────────────────────────────────────────────

model User {
  id               String      @id @default(uuid())
  telegramId       BigInt      @unique
  telegramUsername String?
  firstName        String
  lastName         String?
  status           UserStatus  @default(ACTIVE)
  role             UserRole    @default(PLAYER)
  password         String?     // For web dashboard login
  isAdmin          Boolean     @default(false)
  registeredAt     DateTime    @default(now())
  hasSeenJackpot   Boolean     @default(false)
  lastActiveAt     DateTime    @default(now())
  ipHash           String?     // hashed for privacy
  deviceHash       String?
  phoneNumber      String?

  // Referral / Agent Hierarchy
  referredById     String?
  referredBy       User?       @relation("Referral", fields: [referredById], references: [id])
  referrals        User[]      @relation("Referral")

  agentId          String?     // The Agent who "owns" this player
  agent            User?       @relation("AgentPlayers", fields: [agentId], references: [id])
  players          User[]      @relation("AgentPlayers")

  referralCount    Int         @default(0)

  wallet           Wallet?
  deposits         Deposit[]
  withdrawals      Withdrawal[]
  tickets          Ticket[]
  winners          Winner[]
  transactions     Transaction[]
  auditLogs        AdminLog[]   @relation("AuditUser")
  adminActions     AdminLog[]   @relation("AdminActor")

  @@index([telegramId])
  @@index([status])
  @@index([role])
  @@map("users")
}

model Jackpot {
  id              String   @id @default("GLOBAL")
  currentAmount   Decimal  @default(0) @db.Decimal(18, 2)
  targetAmount    Decimal  @default(1000) @db.Decimal(18, 2)
  minTickets      Int      @default(10)      // Minimum tickets in game to contribute
  contributionPercent Decimal @default(1) @db.Decimal(5, 2) // 1% of ticket price
  lastWonAt       DateTime?
  lastWinnerId    String?
  updatedAt       DateTime @updatedAt

  @@map("jackpots")
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  balance       Decimal  @default(0) @db.Decimal(18, 2)
  bonusBalance  Decimal  @default(0) @db.Decimal(18, 2)
  commissionBalance Decimal @default(0) @db.Decimal(18, 2) // Added for Agents
  coins         Int      @default(0)
  totalDeposited Decimal @default(0) @db.Decimal(18, 2)
  totalWithdrawn Decimal @default(0) @db.Decimal(18, 2)
  totalWon      Decimal  @default(0) @db.Decimal(18, 2)
  totalSpent    Decimal  @default(0) @db.Decimal(18, 2)
  totalCommissionEarned Decimal @default(0) @db.Decimal(18, 2) // Added for Agents
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model Deposit {
  id            String        @id @default(uuid())
  userId        String
  amount        Decimal       @db.Decimal(18, 2)
  reference     String?       // payment reference number
  screenshotUrl String?       // uploaded screenshot path
  status        DepositStatus @default(PENDING)
  adminNote     String?
  approvedBy    String?       // admin user id
  approvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("deposits")
}

model Withdrawal {
  id             String           @id @default(uuid())
  userId         String
  amount         Decimal          @db.Decimal(18, 2)
  accountName    String
  accountNumber  String
  bankName       String
  status         WithdrawalStatus @default(PENDING)
  adminNote      String?
  approvedBy     String?
  approvedAt     DateTime?
  processedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user           User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("withdrawals")
}

model Room {
  id              String     @id @default(uuid())
  type            RoomType
  ticketPrice     Decimal    @db.Decimal(18, 2)
  minPlayers      Int
  maxPlayers      Int        @default(100)
  currentPlayers  Int        @default(0)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())

  games           Game[]

  @@map("rooms")
}

model Game {
  id              String      @id @default(uuid())
  roomId          String
  status          GameStatus  @default(WAITING)
  totalPrize      Decimal     @default(0) @db.Decimal(18, 2)
  houseEdge       Decimal     @default(0) @db.Decimal(18, 2)
  countdownSeconds Int?
  startedAt       DateTime?
  finishedAt      DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  room            Room        @relation(fields: [roomId], references: [id])
  tickets         Ticket[]
  drawHistory     DrawHistory[]
  winners         Winner[]

  @@index([status])
  @@index([roomId])
  @@map("games")
}

model Ticket {
  id        String    @id @default(uuid())
  userId    String
  gameId    String
  card      Json      // 5x5 bingo card as JSON
  markedNumbers Int[] // numbers auto-marked
  isWinner  Boolean   @default(false)
  purchasedAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  game      Game      @relation(fields: [gameId], references: [id])
  winners   Winner[]

  @@index([userId, gameId]) // allow multiple tickets per user per game
  @@index([gameId])
  @@index([userId])
  @@map("tickets")
}

model DrawHistory {
  id         String   @id @default(uuid())
  gameId     String
  number     Int
  drawnAt    DateTime @default(now())
  sequence   Int      // draw order (1st, 2nd, 3rd...)

  game       Game     @relation(fields: [gameId], references: [id])

  @@index([gameId])
  @@map("draw_history")
}

model Winner {
  id         String   @id @default(uuid())
  gameId     String
  userId     String
  ticketId   String
  winMode    WinMode
  prizeAmount Decimal @db.Decimal(18, 2)
  paidAt     DateTime @default(now())

  game       Game     @relation(fields: [gameId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  ticket     Ticket   @relation(fields: [ticketId], references: [id])

  @@index([gameId])
  @@index([userId])
  @@map("winners")
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String
  type        TransactionType
  amount      Decimal           @db.Decimal(18, 2)
  balanceBefore Decimal         @db.Decimal(18, 2)
  balanceAfter  Decimal         @db.Decimal(18, 2)
  status      TransactionStatus @default(PENDING)
  referenceId String?           // deposit/withdrawal/game id
  description String?
  createdAt   DateTime          @default(now())

  user        User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@map("transactions")
}

model AdminLog {
  id          String   @id @default(uuid())
  adminId     String
  targetUserId String?
  action      String
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  admin       User     @relation("AdminActor", fields: [adminId], references: [id])
  targetUser  User?    @relation("AuditUser", fields: [targetUserId], references: [id])

  @@index([adminId])
  @@index([action])
  @@map("admin_logs")
}
