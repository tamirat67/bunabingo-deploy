{
  "expo": {
    "name": "buna-wallet",
    "slug": "buna-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c84f276d-0ded-4c90-8d6f-bd420c186008",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.tamirat_tanga.bunawallet"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Buna Wallet uses your camera to scan QR codes for payments."
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c84f276d-0ded-4c90-8d6f-bd420c186008"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
