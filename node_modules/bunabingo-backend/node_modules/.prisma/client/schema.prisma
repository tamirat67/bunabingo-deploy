generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  telegramId       BigInt?  @unique @map("telegram_id")
  telegramUsername String?  @map("telegram_username")
  username         String?
  firstName        String?  @map("first_name")
  lastName         String?  @map("last_name")
  phoneNumber      String?  @map("phone")
  passwordHash     String?  @map("password_hash")
  referralCode     String?  @unique @map("referral_code")
  referredById     String?  @map("referred_by") @db.Uuid
  role             String   @default("player")
  status           String   @default("active")
  parentId         String?  @map("parent_id") @db.Uuid
  branchId         String?  @map("branch_id") @db.Uuid
  isAdmin          Boolean  @default(false) @map("is_admin")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  referrer  User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals User[]  @relation("Referrals")
  parent    User?   @relation("Hierarchy", fields: [parentId], references: [id])
  children  User[]  @relation("Hierarchy")
  branch    Branch? @relation(fields: [branchId], references: [id])

  wallet       Wallet?
  cartelas     Cartela[]
  deposits     Deposit[]
  withdrawals  Withdrawal[]
  transactions Transaction[]
  agentSales   AgentSale[]
  spinGames    SpinGame[]
  winners      Winner[]
  tickets      Ticket[]

  @@map("users")
}

model Branch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  location  String?
  managerId String?  @map("manager_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  users User[]

  @@map("branches")
}

model Wallet {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  balance         Decimal  @default(0) @db.Decimal(20, 4)
  credit          Decimal  @default(0) @db.Decimal(20, 4)
  commissionRate  Decimal  @default(0.20) @map("commission_rate") @db.Decimal(5, 4)
  referralBalance Decimal  @default(0) @map("referral_balance") @db.Decimal(20, 4)
  bonusBalance    Decimal  @default(0) @map("bonus_balance") @db.Decimal(20, 4)
  freeSpins       Int      @default(0) @map("free_spins")
  totalWon        Decimal  @default(0) @map("total_won") @db.Decimal(20, 4)
  totalSpent      Decimal  @default(0) @map("total_spent") @db.Decimal(20, 4)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Room {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type           String   @default("STANDARD")
  ticketPrice    Decimal  @default(20) @map("ticket_price") @db.Decimal(20, 4)
  minPlayers     Int      @default(2) @map("min_players")
  maxPlayers     Int      @default(100) @map("max_players")
  currentPlayers Int      @default(0) @map("current_players")
  status         String   @default("ACTIVE")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  games Game[]

  @@map("rooms")
}

model Game {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId           String    @map("room_id") @db.Uuid
  status           String    @default("WAITING")
  totalPrize       Decimal   @default(0) @map("total_prize") @db.Decimal(20, 4)
  houseEdge        Decimal   @default(0) @map("house_edge") @db.Decimal(20, 4)
  calledNumbers    Int[]     @default([]) @map("called_numbers")
  countdownSeconds Int?      @map("countdown_seconds")
  startedAt        DateTime? @map("started_at") @db.Timestamptz
  finishedAt       DateTime? @map("finished_at") @db.Timestamptz
  cancelledAt      DateTime? @map("cancelled_at") @db.Timestamptz
  cancelReason     String?   @map("cancel_reason")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  room        Room          @relation(fields: [roomId], references: [id])
  tickets     Ticket[]
  winners     Winner[]
  drawHistory DrawHistory[]

  @@map("games")
}

model Ticket {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gameId        String   @map("game_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  cartelaId     Int      @default(1) @map("cartela_id")
  card          Json?
  markedNumbers Int[]    @default([]) @map("marked_numbers")
  isWinner      Boolean  @default(false) @map("is_winner")
  purchasedAt   DateTime @default(now()) @map("purchased_at") @db.Timestamptz

  game    Game     @relation(fields: [gameId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  winners Winner[]

  @@map("tickets")
}

model Winner {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gameId      String   @map("game_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  ticketId    String   @map("ticket_id") @db.Uuid
  winMode     String   @default("FULL_HOUSE") @map("win_mode")
  prizeAmount Decimal  @map("prize_amount") @db.Decimal(20, 4)
  paidAt      DateTime @default(now()) @map("paid_at") @db.Timestamptz

  game   Game   @relation(fields: [gameId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@map("winners")
}

model DrawHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  number    Int
  sequence  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  game Game @relation(fields: [gameId], references: [id])

  @@map("draws")
}

model Deposit {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  amount     Decimal  @db.Decimal(20, 4)
  reference  String   @unique @map("txn_id")
  receiptUrl String?  @map("receipt_url")
  details    String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@map("deposits")
}

model Withdrawal {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  amount        Decimal   @db.Decimal(18, 2)
  accountName   String    @map("account_name")
  accountNumber String    @map("account_number")
  bankName      String    @map("bank_name")
  status        String    @default("PENDING")
  adminNote     String?   @map("admin_note")
  approvedBy    String?   @map("approved_by")
  approvedAt    DateTime? @map("approved_at")
  processedAt   DateTime? @map("processed_at")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("withdrawals")
}

model Transaction {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  type          String
  amount        Decimal  @db.Decimal(18, 2)
  balanceBefore Decimal  @map("balance_before") @db.Decimal(18, 2)
  balanceAfter  Decimal  @map("balance_after") @db.Decimal(18, 2)
  status        String   @default("COMPLETED")
  referenceId   String?  @map("reference_id")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model AdminLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId      String   @map("admin_id") @db.Uuid
  targetUserId String?  @map("target_user_id") @db.Uuid
  action       String
  details      Json?
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("admin_logs")
}

model GameSettings {
  id                  String   @id @default("global")
  totalCommissionRate Decimal  @default(0.25) @map("total_commission_rate") @db.Decimal(5, 4)
  systemFeeRate       Decimal  @default(0.20) @map("system_fee_rate") @db.Decimal(5, 4)
  callInterval        Int      @default(4) @map("call_interval")
  isManualMode        Boolean  @default(true) @map("is_manual_mode")
  cartelConfig        Json?    @map("cartel_config")
  manualCartelas      Json     @default("{}") @map("manual_cartelas")
  language            String   @default("en")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("game_settings")
}

model AgentSale {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId    String   @map("agent_id") @db.Uuid
  amount     Decimal  @db.Decimal(20, 4)
  commission Decimal  @db.Decimal(20, 4)
  gameType   String   @default("bingo") @map("game_type")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  agent User @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_sales")
}

model SpinGame {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  selectedNumbers Int[]    @map("selected_numbers")
  winningNumber   Int?     @map("winning_number")
  stake           Decimal? @db.Decimal(20, 4)
  prize           Decimal  @default(0) @db.Decimal(20, 4)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@map("spin_games")
}

model Cartela {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  roomId       String?  @map("room_id")
  serialNumber String?  @map("serial_number")
  cartelaIndex Int?     @map("cartela_index")
  numbers      Json?
  isWinner     Boolean  @default(false) @map("is_winner")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@map("cartelas")
}
